{
  "version": 2,
  "routes": [
    {
      "src": "/api/auth",
      "dest": "/api/auth.js"
    },
    {
      "src": "/api/blog",
      "dest": "/api/blog.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "api/auth.js": {
      "maxDuration": 5
    },
    "api/blog.js": {
      "maxDuration": 5
    }
  }
}
